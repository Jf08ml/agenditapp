# Firebase Admin (Firestore, colección de leads)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Notificación de leads por email
MAILER_URL=https://api-email-sending.vercel.app
LEADS_NOTIFY_EMAIL=

# Meta Pixel + Conversions API (landing /oferta)
# El Pixel ID es público (va al browser), no es secreto.
NEXT_PUBLIC_META_PIXEL_ID=1682566646288789
# Token server-only. Se genera en Events Manager > (dataset del pixel) >
# Configuración > Conversions API > Generar token de acceso.
META_CAPI_ACCESS_TOKEN=
# Solo para validar en Events Manager > Test Events. Vaciar/remover
# antes de lanzar tráfico real o los eventos no contarán para optimización.
META_CAPI_TEST_EVENT_CODE=
